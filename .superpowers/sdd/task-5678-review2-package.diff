++def analyse_gaps(
++    user_skills: list[ExtractedSkill],
++    tiered_role_skills: list[TieredSkill],
++) -> tuple[list[GapItem], CoverageScore]:
++    user_skill_names = {s.name.lower() for s in user_skills}
++    gaps: list[GapItem] = []
